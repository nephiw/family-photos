# Django Core Settings
SECRET_KEY=your-django-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Optional S3 Cloud Storage Configuration
# Set USE_S3=True to enable AWS S3 for hosting photos. Otherwise, local storage is used.
USE_S3=False
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_STORAGE_BUCKET_NAME=your-s3-bucket-name
AWS_S3_REGION_NAME=us-east-1

# Optional Cloudinary Storage Configuration
# Set USE_CLOUDINARY=True to enable Cloudinary for photo hosting.
USE_CLOUDINARY=False
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret
